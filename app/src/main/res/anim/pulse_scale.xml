<?xml version="1.0" encoding="utf-8"?>
<!--
    pulse_scale.xml — Animação de pulso contínuo (infinito)
    ─────────────────────────────────────────────────────────
    Usado pelo OfflineTap.java para o ícone da torneira.
    Para os botões de volume da Home, usar pulse_scale_once.xml
    (pulsação única, disparada aleatoriamente via Home.java).
-->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:anim/accelerate_decelerate_interpolator">

    <scale
        android:fromXScale="1.0"
        android:toXScale="1.06"
        android:fromYScale="1.0"
        android:toYScale="1.06"
        android:pivotX="50%"
        android:pivotY="50%"
        android:duration="750"
        android:repeatMode="reverse"
        android:repeatCount="infinite" />

</set>
