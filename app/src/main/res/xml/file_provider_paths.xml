<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider paths — ChoppON v3.2.0
    Utilizado pelo sistema de atualização de APK em ServiceTools.java.
    Permite que o FileProvider exponha arquivos do diretório Downloads
    público para o Intent de instalação sem expor o caminho real do arquivo.
-->
<paths>
    <!-- Downloads públicos: Environment.DIRECTORY_DOWNLOADS -->
    <external-path
        name="external_downloads"
        path="Download/" />
</paths>
