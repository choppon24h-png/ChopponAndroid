<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoAcesso"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_choppon"
            android:layout_marginBottom="8dp" />

        <!-- Título -->
        <TextView
            android:id="@+id/txtTituloAcesso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesso Master"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Versão instalada -->
        <TextView
            android:id="@+id/txtVersaoAtual"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Versão instalada: —"
            android:textColor="#888888"
            android:textSize="12sp"
            android:layout_marginBottom="32dp" />

        <!-- Botão: Acesso QR Code -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcessoQrCode"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Acesso QR Code"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão: Acesso Senha -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcessoSenha"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Acesso Senha"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Botão: Verificar Atualização -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerificarAtualizacao"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1976D2"
            android:text="Verificar Atualização"
            android:textColor="@color/white"
            android:textSize="15sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_launcher_foreground"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            android:layout_marginBottom="8dp" />

        <!-- ProgressBar de download (oculto por padrão) -->
        <ProgressBar
            android:id="@+id/progressUpdate"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:indeterminate="true"
            android:indeterminateTint="@color/choppon_orange"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Container QR Code -->
        <LinearLayout
            android:id="@+id/layoutQrAcesso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imgQrCode"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:contentDescription="QR Code Master"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/progressQr"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/choppon_orange"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtStatusQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/choppon_orange"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Campo de Senha (oculto por padrão) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutInputSenha"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Digite a senha de 6 dígitos"
            android:visibility="gone"
            app:boxStrokeColor="@color/choppon_orange">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSenhaAcesso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:maxLength="6" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
