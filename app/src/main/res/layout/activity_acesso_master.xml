<?xml version="1.0" encoding="utf-8"?>
<!--
    AcessoMaster — layout simplificado.
    Contém APENAS os dois métodos de autenticação:
      1. Acesso QR Code (gerado no tablet, escaneado pelo ERP)
      2. Acesso Senha (6 dígitos)

    "Verificar Atualização" foi migrado para activity_service_tools.xml (ServiceTools).
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoAcesso"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_choppon"
            android:layout_marginBottom="16dp" />

        <!-- Título -->
        <TextView
            android:id="@+id/txtTituloAcesso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Acesso Master"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Subtítulo informativo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Escolha o método de autenticação"
            android:textColor="#888888"
            android:textSize="13sp"
            android:layout_marginBottom="32dp" />

        <!-- ── Botão: Acesso QR Code ───────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcessoQrCode"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Acesso QR Code"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_launcher_foreground"
            app:iconSize="22dp"
            app:iconTint="@color/white"
            android:layout_marginBottom="14dp" />

        <!-- ── Botão: Acesso Senha ────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcessoSenha"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Acesso Senha"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_launcher_foreground"
            app:iconSize="22dp"
            app:iconTint="@color/white"
            android:layout_marginBottom="24dp" />

        <!-- ── Container QR Code (oculto por padrão) ─────────────────────── -->
        <LinearLayout
            android:id="@+id/layoutQrAcesso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:visibility="gone">

            <!-- QR Code gerado localmente via ZXing -->
            <ImageView
                android:id="@+id/imgQrCode"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:contentDescription="QR Code Master"
                android:scaleType="fitCenter"
                android:visibility="gone" />

            <!-- Spinner enquanto gera / aguarda aprovação -->
            <ProgressBar
                android:id="@+id/progressQr"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/choppon_orange"
                android:visibility="gone" />

            <!-- Mensagem de status do QR -->
            <TextView
                android:id="@+id/txtStatusQr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:text=""
                android:textColor="@color/choppon_orange"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Campo de Senha (oculto por padrão) ────────────────────────── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutInputSenha"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Digite a senha de 6 dígitos"
            android:visibility="gone"
            app:boxStrokeColor="@color/choppon_orange">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSenhaAcesso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberPassword"
                android:maxLength="6" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
