<?xml version="1.0" encoding="utf-8"?>
<!--
    CORREÇÃO: 3 bugs corrigidos neste arquivo
    1. btnConfig referenciava @+id/logoChoppOn (inexistente) → corrigido para @+id/logoChoppOn2
    2. Ordem dos botões estava invertida no ConstraintLayout (btnChangePulsos apontava para
       btnSalvarTimeout que estava abaixo dele, criando ciclo de dependência)
    3. Removida referência circular: textView12 apontava para cardBebida2 que está acima dele
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainCalibrar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:visibility="visible">

    <!-- Logo centralizado no topo -->
    <ImageView
        android:id="@+id/logoChoppOn2"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Logo Chopp ON"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_choppon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Botão de configurações no canto superior direito — âncora corrigida para logoChoppOn2 -->
    <Button
        android:id="@+id/btnConfig"
        android:layout_width="80dp"
        android:layout_height="70dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/background"
        android:includeFontPadding="true"
        android:paddingLeft="0dp"
        android:paddingTop="0dp"
        android:paddingRight="0dp"
        android:paddingBottom="0dp"
        android:textColorLink="@color/white"
        android:visibility="visible"
        app:cornerRadius="12dp"
        app:icon="@mipmap/ic_support_foreground"
        app:iconPadding="0dp"
        app:iconSize="110dp"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="@+id/logoChoppOn2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.953"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.571" />

    <!-- Card de informações: pulsos e volume — abaixo do logo -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBebida2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/cardview_dark_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintDimensionRatio="21:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logoChoppOn2"
        app:layout_constraintWidth_max="600dp">

        <LinearLayout
            android:id="@+id/backg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/textView10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="Quantidade de pulsos atual"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtTimeoutAtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:width="200sp"
                android:textAlignment="center"
                android:textColor="@color/choppon_orange"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/textView7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:text="Volume liberado"
                android:textColor="@color/white"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/txtVolumeLiberado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/choppon_orange"
                android:textSize="30dp" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Label "Volume aferido" — abaixo do card -->
    <TextView
        android:id="@+id/textView12"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Volume aferido"
        android:textColor="@color/black"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardBebida2" />

    <!-- Campo de entrada do volume aferido -->
    <EditText
        android:id="@+id/edtNovoTimeout"
        android:layout_width="249dp"
        android:layout_height="67dp"
        android:layout_marginTop="4dp"
        android:ems="10"
        android:inputType="number"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView12" />

    <!-- Botão: Liberar líquido (envia $ML:100) -->
    <Button
        android:id="@+id/btnSalvarTimeout"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/choppon_orange"
        android:text="Liberar liquido"
        android:textColor="@color/white"
        android:textSize="25dp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edtNovoTimeout" />

    <!-- Botão: Calibrar (calcula e envia $PL:valor) -->
    <Button
        android:id="@+id/btnChangePulsos"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/choppon_orange"
        android:text="Calibrar"
        android:textColor="@color/white"
        android:textSize="25dp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnSalvarTimeout" />

    <!-- Botão: Liberação contínua -->
    <Button
        android:id="@+id/btnLiberacaoContinua"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/choppon_orange"
        android:text="Liberação continua"
        android:textColor="@color/white"
        android:textSize="25dp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnChangePulsos" />

    <!-- Botão: Modificar Timeout -->
    <Button
        android:id="@+id/btnTimeout"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/choppon_orange"
        android:text="Modificar Timeout"
        android:textColor="@color/white"
        android:textSize="25dp"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnLiberacaoContinua" />

    <!-- Botão: Voltar para Home -->
    <Button
        android:id="@+id/btnVoltar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#FF5252"
        android:text="&#8592; Voltar"
        android:textColor="@color/white"
        android:textSize="25dp"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnTimeout" />

</androidx.constraintlayout.widget.ConstraintLayout>
