<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainCalibrar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- HEADER                                                         -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnVoltar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="← Voltar"
                android:textSize="12sp"
                android:backgroundTint="#333333"
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Calibração do Sensor"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View android:layout_width="80dp" android:layout_height="1dp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- DISPLAY VOLUME LIBERADO                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:id="@+id/txtVolumeLiberado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.000 ML"
            android:textColor="#00E5FF"
            android:textSize="48sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txtStatusOperacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFC107"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- PULSOS / LITRO ATUAL                                           -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1E1E1E"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pulsos/Litro atual:"
                android:textColor="#AAAAAA"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtTimeoutAtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SECAO: TESTE RAPIDO — 100 mL                                   -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TESTE RÁPIDO"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnSalvarTimeout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Liberar 100 mL"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnLiberacaoContinua"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Liberação Contínua"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SECAO: CALIBRACAO AUTOMATICA — 3 ETAPAS                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CALIBRAÇÃO AUTOMÁTICA"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <!-- ─────────────────────────────────────────────────────────── -->
        <!-- ETAPA 1: Inserir volume desejado (visivel em IDLE)           -->
        <!-- ─────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/painelVolumeDesejado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2A1A"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Etapa 1 — Defina o volume para calibrar"
                android:textColor="#81C784"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Informe quantos mL deseja dispensar para calibração (ex: 300). Posicione a proveta antes de confirmar."
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/edtVolumeDesejado"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:hint="Volume (mL)"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:background="#2A2A2A"
                    android:padding="12dp"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mL"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnIniciarCal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Confirmar e Iniciar Calibração"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#1565C0"
                android:textColor="#FFFFFF"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- ─────────────────────────────────────────────────────────── -->
        <!-- ETAPA 2: Dispensando (visivel em CAL_DISPENSANDO)            -->
        <!-- ─────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/painelDispensando"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1A2A"
            android:padding="14dp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtVolumeAlvo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Dispensando — aguarde o término"
                android:textColor="#90CAF9"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progressCal"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:indeterminate="true"
                android:progressTint="#1565C0"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Não remova a proveta durante a dispensação"
                android:textColor="#888888"
                android:textSize="12sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- ─────────────────────────────────────────────────────────── -->
        <!-- ETAPA 3: Informar volume medido (visivel em CAL_AGUARDANDO)  -->
        <!-- ─────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/painelMedicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A2A2A"
            android:padding="14dp"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Etapa 3 — Informe o volume real medido"
                android:textColor="#4DB6AC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="A dispensação terminou. Leia o volume na proveta e informe abaixo. O sistema calculará e gravará o novo fator de calibração."
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/edtVolumeMedido"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:hint="Volume medido (mL)"
                    android:inputType="numberDecimal"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:background="#2A2A2A"
                    android:padding="12dp"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="mL"
                    android:textColor="#AAAAAA"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <Button
                    android:id="@+id/btnCancelarCal"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Cancelar"
                    android:textSize="13sp"
                    android:backgroundTint="#555555"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnConfirmarCal"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:text="Confirmar Medição"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:backgroundTint="#00796B"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Painel legado — mantido oculto para compatibilidade de ID -->
        <LinearLayout
            android:id="@+id/painelConfirmacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- SECAO: PULSOS / LITRO MANUAL                                   -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AJUSTE MANUAL DE PULSOS/LITRO"
            android:textColor="#888888"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edtNovoTimeout"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:hint="Pulsos/Litro"
                android:inputType="number"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#2A2A2A"
                android:padding="12dp"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnChangePulsos"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="Salvar PL"
                android:textSize="13sp"
                android:backgroundTint="#37474F"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- BOTAO MODIFICAR TIMEOUT                                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Button
            android:id="@+id/btnTimeout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Modificar Timeout"
            android:textSize="13sp"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
