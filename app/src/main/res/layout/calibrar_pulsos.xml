<?xml version="1.0" encoding="utf-8"?>
<!--
    calibrar_pulsos.xml — Tela de calibracao do sensor de fluxo
    Protocolo ESP32 NUS v1.0.0 (2026-05-05)

    Funcoes:
      1. Liberar 100 mL ($ML:100) — teste rapido
      2. Liberacao continua ($LB:) — fecha por $ML:0
      3. Calibracao automatica ($CA:300 -> $CF:<ml_real>) — 2 passos
      4. Salvar pulsos/litro manual ($PL:<n>)
      5. Modificar Timeout -> navega para ModificarTimeout

    Volume Aferido: exibe VP: em tempo real para qualquer funcao ativa.
    Painel de Calibracao: aparece somente apos CA: recebido do ESP32.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/mainCalibrar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/logoChoppOn2"
            android:layout_width="300dp"
            android:layout_height="80dp"
            android:layout_marginTop="8dp"
            android:contentDescription="Logo Chopp ON"
            android:scaleType="fitCenter"
            android:src="@drawable/logo_choppon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botao configuracoes -->
        <Button
            android:id="@+id/btnConfig"
            android:layout_width="80dp"
            android:layout_height="70dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/background"
            android:paddingLeft="0dp"
            android:paddingTop="0dp"
            android:paddingRight="0dp"
            android:paddingBottom="0dp"
            android:visibility="visible"
            app:cornerRadius="12dp"
            app:icon="@mipmap/ic_support_foreground"
            app:iconPadding="0dp"
            app:iconSize="110dp"
            app:iconTint="@color/black"
            app:layout_constraintBottom_toBottomOf="@+id/logoChoppOn2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.953"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.571" />

        <!-- Card: Pulsos/Litro atual + Volume Aferido em tempo real -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBebida2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/cardview_dark_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/logoChoppOn2"
            app:layout_constraintWidth_max="600dp">

            <LinearLayout
                android:id="@+id/backg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- Pulsos/Litro atual -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:id="@+id/textView10"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pulsos/Litro: "
                        android:textColor="@color/white"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/txtTimeoutAtual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/choppon_orange"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Divisor interno -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="16dp"
                    android:background="#44FFFFFF" />

                <!-- Label Volume Aferido -->
                <TextView
                    android:id="@+id/textView7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Volume Aferido"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

                <!-- Valor do volume em tempo real (VP:) -->
                <TextView
                    android:id="@+id/txtVolumeLiberado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="0.000 ML"
                    android:textColor="@color/choppon_orange"
                    android:textSize="38sp"
                    android:textStyle="bold" />

                <!-- Status da operacao atual -->
                <TextView
                    android:id="@+id/txtStatusOperacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Secao: Calibracao Manual (PL direto) -->
        <TextView
            android:id="@+id/textView12"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Pulsos/Litro manual"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardBebida2" />

        <EditText
            android:id="@+id/edtNovoTimeout"
            android:layout_width="249dp"
            android:layout_height="60dp"
            android:layout_marginTop="4dp"
            android:ems="10"
            android:hint="Valor (ex: 5880)"
            android:inputType="number"
            android:textColor="@color/black"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView12" />

        <!-- Botao: Salvar PL manual -->
        <Button
            android:id="@+id/btnChangePulsos"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Salvar Pulsos/Litro"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/edtNovoTimeout" />

        <!-- Divisor -->
        <View
            android:id="@+id/divider1"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="@color/cardview_dark_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnChangePulsos" />

        <!-- Secao: Testes de Fluxo -->
        <TextView
            android:id="@+id/lblTestes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Testes de Fluxo"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider1" />

        <!-- Botao: Liberar 100mL -->
        <Button
            android:id="@+id/btnSalvarTimeout"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Liberar 100 mL"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lblTestes" />

        <!-- Botao: Liberacao continua -->
        <Button
            android:id="@+id/btnLiberacaoContinua"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Liberacao Continua"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnSalvarTimeout" />

        <!-- Divisor -->
        <View
            android:id="@+id/divider2"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="@color/cardview_dark_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnLiberacaoContinua" />

        <!-- Secao: Calibracao Automatica -->
        <TextView
            android:id="@+id/lblCalibracao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Calibracao Automatica"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider2" />

        <!-- Botao: Iniciar Calibracao ($CA:300) -->
        <Button
            android:id="@+id/btnIniciarCal"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="#1565C0"
            android:text="Iniciar Calibracao (300 mL)"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lblCalibracao" />

        <!-- Painel de confirmacao: visivel somente apos CA: recebido -->
        <LinearLayout
            android:id="@+id/painelConfirmacao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="24dp"
            android:background="#EEF2FF"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnIniciarCal">

            <TextView
                android:id="@+id/txtInstrucaoCal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Meca o volume na proveta e informe abaixo:"
                android:textColor="#1565C0"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtVolumeMedido"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:hint="Volume medido na proveta (mL)"
                android:inputType="number"
                android:textColor="@color/black"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnConfirmarCal"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="#2E7D32"
                android:text="Confirmar Medicao"
                android:textColor="@color/white"
                android:textSize="18sp"
                app:cornerRadius="8dp" />

        </LinearLayout>

        <!-- Divisor -->
        <View
            android:id="@+id/divider3"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:background="@color/cardview_dark_background"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/painelConfirmacao" />

        <!-- Botao: Modificar Timeout -->
        <Button
            android:id="@+id/btnTimeout"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/choppon_orange"
            android:text="Modificar Timeout"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider3" />

        <!-- Botao: Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="0dp"
            android:layout_height="70dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="24dp"
            android:backgroundTint="#FF5252"
            android:text="&#8592; Voltar"
            android:textColor="@color/white"
            android:textSize="20sp"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnTimeout" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
