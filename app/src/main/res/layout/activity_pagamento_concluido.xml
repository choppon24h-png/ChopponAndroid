<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_pagamento_concluido.xml
    Tela exibida após pagamento confirmado, durante a liberação do chopp via BLE/ESP32.

    Novos elementos adicionados (v2.0):
      - txtStatusLiberacao : linha de status em tempo real (AUTH:OK, VP:, ML:, ERRO, etc.)
      - progressLiberacao  : barra de progresso proporcional ao volume liberado (VP:)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".PagamentoConcluido">

    <!-- Logo topo -->
    <ImageView
        android:id="@+id/logoChoppOn3"
        android:layout_width="300dp"
        android:layout_height="80dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Logo Chopp ON"
        android:scaleType="fitCenter"
        android:src="@drawable/logo_choppon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Imagem da bebida -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBebida3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/logoChoppOn3"
        app:layout_constraintWidth_max="600dp">

        <ImageView
            android:id="@+id/imageBeer2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Imagem da bebida"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <!-- Título "Pagamento confirmado" -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/roboto"
        android:text="Pagamento confirmado"
        android:textAlignment="center"
        android:textColor="@color/choppon_orange"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardBebida3" />

    <!-- Card de quantidades -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardBebida2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/cardview_dark_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintDimensionRatio="18:9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:layout_constraintWidth_max="600dp">

        <LinearLayout
            android:id="@+id/backg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/textView8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Quantidade Paga"
                android:textColor="@color/white"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/txtQtdPulsos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ML"
                android:textColor="@color/choppon_orange"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textView9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Quantidade liberada"
                android:textColor="@color/white"
                android:textSize="28sp" />

            <TextView
                android:id="@+id/txtMls"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 ML"
                android:textColor="@color/choppon_orange"
                android:textSize="28sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!--
        ProgressBar de liberação (volume proporcional ao VP: recebido).
        Visível durante a liberação, oculta após ML: recebido.
    -->
    <ProgressBar
        android:id="@+id/progressLiberacao"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="24dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/choppon_orange"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardBebida2"
        app:layout_constraintWidth_max="600dp" />

    <!--
        Texto de status em tempo real: exibe mensagens do protocolo ESP32
        (AUTH:OK, "Servindo...", "Timeout", "Erro", etc.)
    -->
    <TextView
        android:id="@+id/txtStatusLiberacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        android:gravity="center"
        android:text="⏳ Conectando ao dispositivo..."
        android:textColor="#555555"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/progressLiberacao"
        app:layout_constraintWidth_max="600dp" />

    <!--
        Botão "Continuar servindo" / "Liberar Restante".
        Aparece quando ML: é recebido com volume < qtd_ml (fluxo incompleto)
        ou quando watchdog dispara por timeout de fluxo.
        Texto atualizado dinamicamente pelo Java com o volume restante.
    -->
    <Button
        android:id="@+id/btnLiberarRestante"
        android:layout_width="0dp"
        android:layout_height="85dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="24dp"
        android:backgroundTint="@color/choppon_orange"
        android:text="Continuar servindo"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:cornerRadius="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtStatusLiberacao"
        app:layout_constraintWidth_max="600dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
