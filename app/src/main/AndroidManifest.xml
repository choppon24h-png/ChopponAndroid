<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />

    <!-- FIX: Permissões obrigatórias para startForeground() no Android 9+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- FIX: Tipo específico obrigatório no Android 14+ (targetSdk 34+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- Permissão para exibir notificações (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Permissões para sistema de atualização de APK (v3.2.0) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:name=".ChoppOnApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ChoppOnTap"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31" >

        <!-- Tela de IMEI como principal (LAUNCHER) para garantir vínculo -->
        <activity
            android:name=".Imei"
            android:exported="true"
            android:label="Vínculo de Dispositivo"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".Home"
            android:exported="true"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".FormaPagamento"
            android:exported="true"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".PagamentoConcluido"
            android:exported="true"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".CalibrarPulsos"
            android:exported="true"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".ModificarTimeout"
            android:exported="true"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".AcessoMaster"
            android:exported="false"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <activity
            android:name=".ServiceTools"
            android:exported="false"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <!-- Tela OFFLINE: exibida quando a TAP é desativada pelo técnico -->
        <activity
            android:name=".OfflineTap"
            android:exported="false"
            android:screenOrientation="reversePortrait"
            android:theme="@style/Theme.ChoppOnTap" />

        <!-- FIX: foregroundServiceType="connectedDevice" obrigatório no Android 14+
             para serviços que gerenciam conexões Bluetooth -->
        <!-- MUDANÇA 1: BluetoothServiceIndustrial — implementação industrial para ESP32 BLE.
             Serviço BLE único e ativo do aplicativo. -->
        <service
            android:name=".BluetoothServiceIndustrial"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- FileProvider para instalação de APK via sistema de atualização (v3.2.0) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
